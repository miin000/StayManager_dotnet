<Window x:Class="staymanager_pj.Views.Customer.RoomDetailPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:staymanager_pj.Views.Shared"
        Title="Chi tiết phòng"
        Height="900"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <shared:TopBar Grid.Row="0"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Width="940"
                        HorizontalAlignment="Center"
                        Margin="0,24,0,60">

                <TextBlock x:Name="txtTitle"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1F1F1F"/>

                <TextBlock x:Name="txtSubtitle"
                           FontSize="13"
                           Foreground="#666666"
                           Margin="0,6,0,18"/>

                <Grid Height="320">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.35*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#DADADA"
                            CornerRadius="6"
                            Margin="0,0,6,0">
                        <Grid>
                            <TextBlock x:Name="txtRoomNumber"
                                       FontSize="54"
                                       FontWeight="Bold"
                                       Foreground="#4A4A4A"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Background="#C8C8C8"
                                CornerRadius="4"
                                Margin="0,0,6,6"/>

                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Background="#D0D0D0"
                                CornerRadius="4"
                                Margin="0,0,0,6"/>

                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Background="#BDBDBD"
                                CornerRadius="4"
                                Margin="0,0,6,0"/>

                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Background="#1F1F1F"
                                CornerRadius="4"/>
                    </Grid>
                </Grid>

                <Grid Margin="0,34,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="310"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,40,0">
                        <TextBlock Text="Về căn phòng này"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1F1F1F"
                                   Margin="0,0,0,14"/>

                        <TextBlock x:Name="txtDescription"
                                   FontSize="13"
                                   Foreground="#444444"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>

                        <TextBlock Text="Đồ nội thất và vật tư trong phòng"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1F1F1F"
                                   Margin="0,36,0,16"/>

                        <ItemsControl x:Name="icRoomItems">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White"
                                            BorderBrush="#D9D9D9"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12"
                                            Margin="0,0,12,12">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ItemName}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding DetailText}"
                                                       Foreground="#666666"
                                                       FontSize="12"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="txtNoItems"
                                   Text="Phòng này chưa gắn đồ nội thất/vật tư."
                                   Foreground="#666666"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="White"
                            BorderBrush="#D9D9D9"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="18"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtPrice"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#1F1F1F"/>
                                <TextBlock Text=" / đêm"
                                           VerticalAlignment="Bottom"
                                           Foreground="#666666"
                                           Margin="4,0,0,3"/>
                            </StackPanel>

                            <TextBlock x:Name="txtPriceBreakdown"
                                       Foreground="#666666"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,18"/>

                            <TextBlock Text="NHẬN PHÒNG"
                                       FontSize="11"
                                       Foreground="#666666"/>
                            <DatePicker x:Name="dpCheckIn"
                                        Height="32"
                                        Margin="0,4,0,12"/>

                            <TextBlock Text="TRẢ PHÒNG"
                                       FontSize="11"
                                       Foreground="#666666"/>
                            <DatePicker x:Name="dpCheckOut"
                                        Height="32"
                                        Margin="0,4,0,12"/>

                            <TextBlock Text="KHÁCH"
                                       FontSize="11"
                                       Foreground="#666666"/>
                            <ComboBox x:Name="cbGuests"
                                      Height="34"
                                      Margin="0,4,0,18"/>

                            <Button x:Name="btnBookNow"
                                    Content="ĐẶT PHÒNG NGAY"
                                    Height="40"
                                    Background="#4A4A4A"
                                    BorderBrush="#4A4A4A"
                                    Foreground="White"
                                    FontWeight="Bold"/>

                            <Separator Margin="0,18,0,12"/>

                            <DockPanel Margin="0,4">
                                <TextBlock Text="Trạng thái"/>
                                <TextBlock x:Name="txtStatus"
                                           DockPanel.Dock="Right"
                                           FontWeight="SemiBold"/>
                            </DockPanel>

                            <DockPanel Margin="0,4">
                                <TextBlock Text="Sức chứa"/>
                                <TextBlock x:Name="txtCapacity"
                                           DockPanel.Dock="Right"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
