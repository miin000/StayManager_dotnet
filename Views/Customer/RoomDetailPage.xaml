<Window x:Class="staymanager_pj.Views.Customer.RoomDetailPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:staymanager_pj.Views.Shared"
        Title="Chi tiết phòng"
        Height="900"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <shared:TopBar Grid.Row="0"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Width="940"
                        HorizontalAlignment="Center"
                        Margin="0,24,0,60">

                <TextBlock Text="Ocean View Master Suite"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1F1F1F"/>

                <TextBlock Text="2 Guests   1 King Bed   85 m²   4.9 (128 Reviews)"
                           FontSize="13"
                           Foreground="#666666"
                           Margin="0,6,0,18"/>

                <!-- Gallery -->
                <Grid Height="360">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.35*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#DADADA"
                            CornerRadius="6"
                            Margin="0,0,6,0"/>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Background="#C8C8C8"
                                CornerRadius="4"
                                Margin="0,0,6,6"/>

                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Background="#D0D0D0"
                                CornerRadius="4"
                                Margin="0,0,0,6"/>

                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Background="#BDBDBD"
                                CornerRadius="4"
                                Margin="0,0,6,0"/>

                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Background="#1F1F1F"
                                CornerRadius="4"/>
                    </Grid>
                </Grid>

                <Grid Margin="0,34,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- Detail -->
                    <StackPanel Grid.Column="0"
                                Margin="0,0,40,0">
                        <TextBlock Text="Về Căn Phòng Này"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1F1F1F"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="Ocean View Master Suite là biểu tượng của sự tĩnh lặng và đẳng cấp. Được thiết kế với tầm nhìn toàn cảnh ra đại dương bao la, căn phòng mang đến trải nghiệm nghỉ dưỡng hoàn hảo với ánh sáng tự nhiên ngập tràn."
                                   FontSize="13"
                                   Foreground="#444444"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>

                        <TextBlock Text="Tiện Nghi Cao Cấp"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1F1F1F"
                                   Margin="0,36,0,16"/>

                        <UniformGrid Columns="3">
                            <TextBlock Text="Wi-Fi tốc độ cao" Margin="0,6"/>
                            <TextBlock Text="Điều hòa nhiệt độ" Margin="0,6"/>
                            <TextBlock Text="Smart TV 65''" Margin="0,6"/>
                            <TextBlock Text="Máy pha cà phê" Margin="0,6"/>
                            <TextBlock Text="Bồn tắm nằm" Margin="0,6"/>
                            <TextBlock Text="Phục vụ phòng 24/7" Margin="0,6"/>
                        </UniformGrid>

                        <TextBlock Text="Đánh Giá Từ Khách Hàng"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1F1F1F"
                                   Margin="0,40,0,16"/>

                        <Border Background="White"
                                BorderBrush="#D9D9D9"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="Alexander M."
                                           FontWeight="Bold"/>
                                <TextBlock Text="★★★★★"
                                           Foreground="#4A4A4A"
                                           Margin="0,4"/>
                                <TextBlock Text="Tuyệt vời! Tầm nhìn ra biển từ ban công thật sự đáng giá. Phòng cực kỳ sạch sẽ và dịch vụ không chê vào đâu được."
                                           Foreground="#444444"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Booking box -->
                    <Border Grid.Column="1"
                            Background="White"
                            BorderBrush="#D9D9D9"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="18"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="$450"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#1F1F1F"/>
                                <TextBlock Text=" / đêm"
                                           VerticalAlignment="Bottom"
                                           Foreground="#666666"
                                           Margin="4,0,0,3"/>
                            </StackPanel>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Margin="0,0,6,0">
                                    <TextBlock Text="NHẬN PHÒNG"
                                               FontSize="11"
                                               Foreground="#666666"/>
                                    <DatePicker x:Name="dpCheckIn"
                                                Height="32"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Margin="6,0,0,0">
                                    <TextBlock Text="TRẢ PHÒNG"
                                               FontSize="11"
                                               Foreground="#666666"/>
                                    <DatePicker x:Name="dpCheckOut"
                                                Height="32"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="KHÁCH"
                                       FontSize="11"
                                       Foreground="#666666"
                                       Margin="0,14,0,4"/>

                            <ComboBox x:Name="cbGuests"
                                      Height="34">
                                <ComboBoxItem Content="1 Người lớn"/>
                                <ComboBoxItem Content="2 Người lớn"/>
                                <ComboBoxItem Content="2 Người lớn, 1 Trẻ em"/>
                            </ComboBox>

                            <Button x:Name="btnBookNow"
                                    Content="ĐẶT PHÒNG NGAY"
                                    Height="40"
                                    Margin="0,18,0,18"
                                    Background="#4A4A4A"
                                    BorderBrush="#4A4A4A"
                                    Foreground="White"
                                    FontWeight="Bold"/>

                            <DockPanel Margin="0,4">
                                <TextBlock Text="$450 x 5 đêm"/>
                                <TextBlock Text="$2,250"
                                           DockPanel.Dock="Right"/>
                            </DockPanel>

                            <DockPanel Margin="0,4">
                                <TextBlock Text="Phí dịch vụ &amp; Thuế"/>
                                <TextBlock Text="$225"
                                           DockPanel.Dock="Right"/>
                            </DockPanel>

                            <Separator Margin="0,10"/>

                            <DockPanel>
                                <TextBlock Text="Tổng tiền"
                                           FontWeight="Bold"/>
                                <TextBlock Text="$2,475"
                                           DockPanel.Dock="Right"
                                           FontWeight="Bold"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
