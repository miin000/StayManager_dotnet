<Window x:Class="staymanager_pj.Views.Customer.HomePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:staymanager_pj.Views.Shared"
        Title="Trang chủ"
        Height="800"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <shared:TopBar Grid.Row="0"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Banner -->
                <Grid Height="330">
                    <Grid.Background>
                        <SolidColorBrush Color="#D8D8D8"/>
                    </Grid.Background>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="760">
                        <TextBlock Text="Nơi mọi chi tiết được thiết kế tinh xảo"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Tận hưởng không gian nghỉ dưỡng sang trọng, yên tĩnh và đẳng cấp."
                                   FontSize="14"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   Margin="0,0,0,28"/>

                        <Border Background="White"
                                CornerRadius="6"
                                Padding="16"
                                HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Margin="6,0">
                                    <TextBlock Text="Ngày nhận phòng"
                                               FontSize="12"
                                               Foreground="#666666"/>
                                    <DatePicker x:Name="dpCheckIn"
                                                Width="150"
                                                Height="32"/>
                                </StackPanel>

                                <StackPanel Margin="6,0">
                                    <TextBlock Text="Ngày trả phòng"
                                               FontSize="12"
                                               Foreground="#666666"/>
                                    <DatePicker x:Name="dpCheckOut"
                                                Width="150"
                                                Height="32"/>
                                </StackPanel>

                                <StackPanel Margin="6,0">
                                    <TextBlock Text="Khách"
                                               FontSize="12"
                                               Foreground="#666666"/>
                                    <ComboBox x:Name="cbGuests"
                                              Width="130"
                                              Height="32">
                                        <ComboBoxItem Content="1 Người"/>
                                        <ComboBoxItem Content="2 Người"/>
                                        <ComboBoxItem Content="3 Người"/>
                                        <ComboBoxItem Content="4 Người"/>
                                    </ComboBox>
                                </StackPanel>

                                <Button x:Name="btnSearchRoom"
                                        Content="TÌM PHÒNG"
                                        Width="120"
                                        Height="36"
                                        Margin="10,18,0,0"
                                        Background="#4A4A4A"
                                        Foreground="White"
                                        BorderBrush="#4A4A4A"
                                        FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Featured rooms -->
                <StackPanel Margin="0,42,0,20"
                            HorizontalAlignment="Center">
                    <TextBlock Text="Không Gian Tinh Tế"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#1F1F1F"
                               TextAlignment="Center"/>

                    <TextBlock Text="Mỗi căn phòng tại Luxe Reserve là một kiệt tác kiến trúc, kết hợp hoàn hảo giữa tiện nghi hiện đại và nét đẹp cổ điển."
                               FontSize="13"
                               Foreground="#666666"
                               Width="560"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>

                <UniformGrid Columns="3"
                             Width="920"
                             HorizontalAlignment="Center"
                             Margin="0,10,0,60">
                    <!-- Card 1 -->
                    <Border Background="White"
                            CornerRadius="6"
                            Margin="10"
                            BorderBrush="#D9D9D9"
                            BorderThickness="1">
                        <StackPanel>
                            <Border Height="160"
                                    Background="#DADADA"
                                    CornerRadius="6,6,0,0"/>
                            <StackPanel Margin="14">
                                <TextBlock Text="Deluxe Ocean View"
                                           FontSize="17"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Tận hưởng tầm nhìn toàn cảnh đại dương từ ban công riêng."
                                           FontSize="12"
                                           Foreground="#666666"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,12"/>
                                <DockPanel>
                                    <TextBlock Text="2 khách  |  1 giường  |  45m²"
                                               Foreground="#666666"
                                               FontSize="12"/>
                                    <Button x:Name="btnViewDeluxe"
                                            Content="Chi tiết →"
                                            DockPanel.Dock="Right"
                                            HorizontalAlignment="Right"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Foreground="#4A4A4A"/>
                                </DockPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Card 2 -->
                    <Border Background="White"
                            CornerRadius="6"
                            Margin="10"
                            BorderBrush="#D9D9D9"
                            BorderThickness="1">
                        <StackPanel>
                            <Border Height="160"
                                    Background="#C8C8C8"
                                    CornerRadius="6,6,0,0"/>
                            <StackPanel Margin="14">
                                <TextBlock Text="Premium Suite"
                                           FontSize="17"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Không gian phòng khách riêng biệt rộng rãi, phù hợp cho kỳ nghỉ cao cấp."
                                           FontSize="12"
                                           Foreground="#666666"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,12"/>
                                <DockPanel>
                                    <TextBlock Text="2 khách  |  1 giường  |  85m²"
                                               Foreground="#666666"
                                               FontSize="12"/>
                                    <Button x:Name="btnViewPremium"
                                            Content="Chi tiết →"
                                            DockPanel.Dock="Right"
                                            HorizontalAlignment="Right"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Foreground="#4A4A4A"/>
                                </DockPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Card 3 -->
                    <Border Background="White"
                            CornerRadius="6"
                            Margin="10"
                            BorderBrush="#D9D9D9"
                            BorderThickness="1">
                        <StackPanel>
                            <Border Height="160"
                                    Background="#D0D0D0"
                                    CornerRadius="6,6,0,0"/>
                            <StackPanel Margin="14">
                                <TextBlock Text="Royal Penthouse"
                                           FontSize="17"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Đỉnh cao của sự xa hoa với hồ bơi vô cực riêng và quản gia 24/7."
                                           FontSize="12"
                                           Foreground="#666666"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,12"/>
                                <DockPanel>
                                    <TextBlock Text="4 khách  |  2 giường  |  120m²"
                                               Foreground="#666666"
                                               FontSize="12"/>
                                    <Button x:Name="btnViewRoyal"
                                            Content="Chi tiết →"
                                            DockPanel.Dock="Right"
                                            HorizontalAlignment="Right"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Foreground="#4A4A4A"/>
                                </DockPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
