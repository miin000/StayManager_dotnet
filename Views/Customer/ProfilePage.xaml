<Window x:Class="staymanager_pj.Views.Customer.ProfilePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:staymanager_pj.Views.Shared"
        Title="Hồ sơ khách hàng"
        Height="820"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <shared:TopBar Grid.Row="0"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid Width="1000"
                  HorizontalAlignment="Center"
                  Margin="0,36,0,60">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Customer info -->
                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#D9D9D9"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="18"
                        VerticalAlignment="Top">
                    <StackPanel>
                        <Ellipse Width="96"
                                 Height="96"
                                 Fill="#2F2F2F"
                                 HorizontalAlignment="Center"
                                 Margin="0,6,0,14"/>

                        <TextBlock Text="Nguyễn Trần Vân Anh"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextAlignment="Center"/>

                        <TextBlock Text="Thành viên hạng Platinum"
                                   Foreground="#4A4A4A"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   Margin="0,4,0,20"/>

                        <Separator/>

                        <TextBlock Text="Email"
                                   FontSize="12"
                                   Foreground="#666666"
                                   Margin="0,16,0,2"/>
                        <TextBlock Text="vananh.nguyen@example.com"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Số điện thoại"
                                   FontSize="12"
                                   Foreground="#666666"
                                   Margin="0,14,0,2"/>
                        <TextBlock Text="+84 90 123 4567"/>

                        <TextBlock Text="Địa chỉ"
                                   FontSize="12"
                                   Foreground="#666666"
                                   Margin="0,14,0,2"/>
                        <TextBlock Text="Quận 1, TP. Hồ Chí Minh"
                                   TextWrapping="Wrap"/>

                        <Button x:Name="btnEditProfile"
                                Content="Chỉnh sửa hồ sơ"
                                Height="34"
                                Margin="0,22,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Booking history -->
                <StackPanel Grid.Column="1"
                            Margin="26,0,0,0">
                    <TextBlock Text="Quản lý thông tin cá nhân và xem lại các kỳ nghỉ của bạn tại Luxe Reserve."
                               FontSize="13"
                               Foreground="#666666"
                               Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,16">
                        <Button x:Name="btnAllBookings"
                                Content="Tất cả đặt phòng"
                                Height="32"
                                Margin="0,0,8,0"/>
                        <Button x:Name="btnUpcomingBookings"
                                Content="Sắp tới"
                                Height="32"
                                Margin="0,0,8,0"/>
                        <Button x:Name="btnCompletedBookings"
                                Content="Đã hoàn thành"
                                Height="32"
                                Margin="0,0,8,0"/>
                        <Button x:Name="btnCancelledBookings"
                                Content="Đã hủy"
                                Height="32"/>
                    </StackPanel>

                    <!-- Booking item 1 -->
                    <Border Background="White"
                            BorderBrush="#D9D9D9"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Height="95"
                                    Background="#DADADA"
                                    CornerRadius="4"/>

                            <StackPanel Grid.Column="1"
                                        Margin="16,0">
                                <TextBlock Text="Mã: #LR-B4392"
                                           Foreground="#666666"
                                           FontSize="12"/>
                                <TextBlock Text="Ocean View Pool Villa"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,4,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Nhận phòng"
                                                   FontSize="12"
                                                   Foreground="#666666"/>
                                        <TextBlock Text="15/12/2024"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Trả phòng"
                                                   FontSize="12"
                                                   Foreground="#666666"/>
                                        <TextBlock Text="18/12/2024"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Tổng thanh toán"
                                           FontSize="12"
                                           Foreground="#666666"
                                           Margin="0,12,0,0"/>
                                <TextBlock Text="45,000,000 đ"
                                           FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center">
                                <Button x:Name="btnCancelBooking"
                                        Content="Hủy phòng"
                                        Height="32"
                                        Margin="0,0,0,8"
                                        Foreground="#555555"/>
                                <Button x:Name="btnBookingDetail"
                                        Content="Chi tiết"
                                        Height="32"
                                        Background="#2F2F2F"
                                        Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Booking item 2 -->
                    <Border Background="White"
                            BorderBrush="#D9D9D9"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Height="95"
                                    Background="#C8C8C8"
                                    CornerRadius="4"/>

                            <StackPanel Grid.Column="1"
                                        Margin="16,0">
                                <TextBlock Text="Mã: #LR-T1024"
                                           Foreground="#666666"
                                           FontSize="12"/>
                                <TextBlock Text="Executive City Suite"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,4,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Nhận phòng"
                                                   FontSize="12"
                                                   Foreground="#666666"/>
                                        <TextBlock Text="10/09/2024"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Trả phòng"
                                                   FontSize="12"
                                                   Foreground="#666666"/>
                                        <TextBlock Text="12/09/2024"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Tổng thanh toán"
                                           FontSize="12"
                                           Foreground="#666666"
                                           Margin="0,12,0,0"/>
                                <TextBlock Text="12,500,000 đ"
                                           FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center">
                                <Button x:Name="btnRebook"
                                        Content="Đặt lại"
                                        Height="32"
                                        Margin="0,0,0,8"/>
                                <Button x:Name="btnViewInvoice"
                                        Content="Hóa đơn"
                                        Height="32"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
