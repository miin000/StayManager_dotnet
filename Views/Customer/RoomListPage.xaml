<Window x:Class="staymanager_pj.Views.Customer.RoomListPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:staymanager_pj.Views.Shared"
        Title="Danh sách phòng"
        Height="800"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <shared:TopBar Grid.Row="0"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,30,0,50">
                <TextBlock Text="Khám phá không gian nghỉ dưỡng"
                           FontSize="30"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="#1F1F1F"/>

                <TextBlock Text="Lựa chọn không gian phù hợp từ danh sách phòng đang có trong hệ thống."
                           FontSize="13"
                           Foreground="#666666"
                           TextAlignment="Center"
                           Margin="0,8,0,30"/>

                <Grid Width="900"
                      HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="6"
                            Padding="16"
                            BorderBrush="#D9D9D9"
                            BorderThickness="1"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="BỘ LỌC TÌM KIẾM"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       Margin="0,0,0,18"/>

                            <TextBlock Text="Từ khóa"
                                       FontSize="12"
                                       Foreground="#444444"/>
                            <TextBox x:Name="txtSearch"
                                     Height="32"
                                     Margin="0,6,0,14"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Tìm số phòng, loại phòng, mô tả"/>

                            <TextBlock Text="Giá tối đa / đêm"
                                       FontSize="12"
                                       Foreground="#444444"/>
                            <Slider x:Name="slPrice"
                                    Minimum="0"
                                    Maximum="10000000"
                                    Value="10000000"
                                    TickFrequency="500000"
                                    Margin="0,8,0,4"/>
                            <TextBlock x:Name="txtPriceFilter"
                                       TextAlignment="Right"
                                       Foreground="#666666"
                                       FontSize="12"
                                       Margin="0,0,0,14"/>

                            <TextBlock Text="Loại phòng"
                                       FontSize="12"
                                       Foreground="#444444"/>
                            <ComboBox x:Name="cmbRoomType"
                                      Height="32"
                                      Margin="0,6,0,14"/>

                            <Button x:Name="btnApplyFilter"
                                    Content="Áp dụng"
                                    Height="32"
                                    Margin="0,4,0,8"/>
                            <Button x:Name="btnResetFilter"
                                    Content="Thiết lập lại"
                                    Height="32"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="18,0,0,0">
                        <TextBlock x:Name="txtEmpty"
                                   Text="Không có phòng phù hợp."
                                   Visibility="Collapsed"
                                   Foreground="#666666"
                                   Margin="0,0,0,12"/>

                        <ItemsControl x:Name="icRooms">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="220"
                                            Background="White"
                                            CornerRadius="6"
                                            BorderBrush="#D9D9D9"
                                            BorderThickness="1"
                                            Margin="0,0,16,16">
                                        <StackPanel>
                                            <Border Height="125"
                                                    Background="#DADADA"
                                                    CornerRadius="6,6,0,0">
                                                <Grid>
                                                    <TextBlock Text="{Binding RoomNumber}"
                                                               FontSize="28"
                                                               FontWeight="Bold"
                                                               Foreground="#4A4A4A"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Margin="12">
                                                <DockPanel LastChildFill="True">
                                                    <TextBlock Text="{Binding RoomType}"
                                                               FontWeight="Bold"
                                                               FontSize="15"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>

                                                <TextBlock Text="{Binding PriceText}"
                                                           Foreground="#4A4A4A"
                                                           FontWeight="Bold"
                                                           Margin="0,5,0,0"/>

                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="11"
                                                           Foreground="#666666"
                                                           TextWrapping="Wrap"
                                                           Margin="0,10,0,10"
                                                           MinHeight="46"/>

                                                <TextBlock Text="{Binding Summary}"
                                                           FontSize="11"
                                                           Foreground="#666666"/>

                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="#4A4A4A"
                                                           Margin="0,6,0,0"/>

                                                <Button Content="XEM CHI TIẾT"
                                                        Height="30"
                                                        Margin="0,12,0,0"
                                                        Background="White"
                                                        BorderBrush="#4A4A4A"
                                                        Foreground="#4A4A4A"
                                                        Click="BtnDetail_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
