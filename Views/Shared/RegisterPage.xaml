<Window x:Class="staymanager_pj.Views.Shared.RegisterPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký tài khoản"
        Height="760"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left visual -->
        <Grid Grid.Column="0">
            <Grid.Background>
                <SolidColorBrush Color="#3A3A3A"/>
            </Grid.Background>

            <StackPanel VerticalAlignment="Center"
                        Margin="70">
                <TextBlock Text="Luxe Reserve"
                           FontSize="38"
                           FontWeight="Bold"
                           FontStyle="Italic"
                           Foreground="White"/>

                <TextBlock Text="Create your luxury experience"
                           FontSize="16"
                           Foreground="#E5E5E5"
                           Margin="0,8,0,28"/>

                <TextBlock Text="Tạo tài khoản để đặt phòng nhanh hơn, theo dõi lịch sử đặt phòng và quản lý hồ sơ cá nhân."
                           FontSize="17"
                           Foreground="White"
                           TextWrapping="Wrap"
                           LineHeight="28"
                           Width="420"/>
            </StackPanel>
        </Grid>

        <!-- Register form -->
        <ScrollViewer Grid.Column="1"
                      Background="White"
                      VerticalScrollBarVisibility="Auto">
            <Border Width="430"
                    Padding="34"
                    Background="White"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="0,30">
                <StackPanel>
                    <TextBlock Text="Đăng ký tài khoản"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#1F1F1F"/>

                    <TextBlock Text="Vui lòng nhập thông tin để tạo tài khoản khách hàng."
                               FontSize="13"
                               Foreground="#666666"
                               Margin="0,8,0,26"/>

                    <TextBlock Text="Họ và tên"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="txtFullName"
                             Height="38"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Số điện thoại"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="txtPhoneNumber"
                             Height="38"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Email"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="txtEmail"
                             Height="38"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Tên đăng nhập"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="txtUsername"
                             Height="38"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Mật khẩu"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="txtPassword"
                                 Height="38"
                                 Margin="0,0,0,14"/>

                    <TextBlock Text="Nhập lại mật khẩu"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="txtConfirmPassword"
                                 Height="38"
                                 Margin="0,0,0,14"/>

                    <TextBlock Text="CCCD / Passport"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="txtIdentityNumber"
                             Height="38"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Địa chỉ"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="txtAddress"
                             Height="70"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Margin="0,0,0,16"/>

                    <CheckBox x:Name="chkAgree"
                              FontSize="12"
                              Margin="0,0,0,18">
                        <TextBlock TextWrapping="Wrap">
                            Tôi đồng ý với điều khoản sử dụng và chính sách bảo mật.
                        </TextBlock>
                    </CheckBox>

                    <Button x:Name="btnRegister"
                            Content="TẠO TÀI KHOẢN"
                            Height="42"
                            Background="#4A4A4A"
                            BorderBrush="#4A4A4A"
                            Foreground="White"
                            FontWeight="Bold"
                            Margin="0,0,0,16"/>

                    <Separator Margin="0,4,0,16"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Đã có tài khoản?"
                                   Foreground="#666666"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="btnGoToLogin"
                                Content="Đăng nhập"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="#4A4A4A"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
