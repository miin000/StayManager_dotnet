<UserControl x:Class="staymanager_pj.Views.Shared.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="56">
    <Border Background="White"
            BorderBrush="#D9D9D9"
            BorderThickness="0,0,0,1"
            Padding="24,10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="StayManager"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button x:Name="btnHome"
                        Content="Trang chủ"
                        Width="90"
                        Margin="0,0,8,0"/>
                <Button x:Name="btnRoomList"
                        Content="Phòng"
                        Width="80"
                        Margin="0,0,8,0"/>

                <StackPanel x:Name="pnlGuest"
                            Orientation="Horizontal">
                    <Button x:Name="btnLogin"
                            Content="Đăng nhập"
                            Width="90"
                            Margin="0,0,8,0"/>
                    <Button x:Name="btnRegister"
                            Content="Đăng ký"
                            Width="90"/>
                </StackPanel>

                <StackPanel x:Name="pnlAuthenticated"
                            Orientation="Horizontal"
                            Visibility="Collapsed">
                    <TextBlock x:Name="txtWelcome"
                               VerticalAlignment="Center"
                               Foreground="#4A4A4A"
                               FontWeight="SemiBold"
                               Margin="0,0,12,0"/>
                    <Button x:Name="btnLogout"
                            Content="Đăng xuất"
                            Width="90"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
