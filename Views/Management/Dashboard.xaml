<Window x:Class="staymanager_pj.Views.Management.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:staymanager_pj.Views.Shared"
        Title="Dashboard" Height="900" Width="1200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <local:Sidebar Grid.Column="0"/>

        <!-- Main Content -->
        <ScrollViewer Grid.Column="1">
            <StackPanel Margin="20">
                <TextBlock Text="Tổng quan hệ thống" FontSize="24" FontWeight="Bold" Margin="10"/>
                <ItemsControl x:Name="icStats" Margin="10"/>
                <ItemsControl x:Name="icRevenueChart" Margin="10"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
