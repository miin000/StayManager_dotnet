<Window x:Class="staymanager_pj.Views.Management.CheckOutPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:staymanager_pj.Views.Shared"
        Title="Check-In/Check-Out" Height="900" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:Sidebar Grid.Column="0"/>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="10,0,10,12">
                <TextBlock Text="Quản lý Check-in / Check-out" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox x:Name="txtSearch" Width="260" Height="32" Margin="24,0,8,0" VerticalContentAlignment="Center" ToolTip="Tìm khách, số phòng, mã hóa đơn"/>
                <Button x:Name="btnSearch" Content="Tìm" Width="70" Height="32" Margin="0,0,8,0"/>
                <Button x:Name="btnRefresh" Content="Tải lại" Width="80" Height="32" Margin="0,0,16,0"/>
                <TextBlock Text="Thanh toán" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbPaymentMethod" Width="140" Height="32"/>
            </StackPanel>

            <DataGrid x:Name="dgFrontDesk"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Margin="10,0,10,10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã đặt" Binding="{Binding ReservationId}" Width="70"/>
                    <DataGridTextColumn Header="Khách" Binding="{Binding CustomerName}" Width="150"/>
                    <DataGridTextColumn Header="Điện thoại" Binding="{Binding PhoneNumber}" Width="110"/>
                    <DataGridTextColumn Header="Phòng" Binding="{Binding RoomNumber}" Width="70"/>
                    <DataGridTextColumn Header="Loại" Binding="{Binding RoomType}" Width="110"/>
                    <DataGridTextColumn Header="Nhận" Binding="{Binding CheckInDate, StringFormat={}{0:dd/MM/yyyy}}" Width="100"/>
                    <DataGridTextColumn Header="Trả" Binding="{Binding CheckOutDate, StringFormat={}{0:dd/MM/yyyy}}" Width="100"/>
                    <DataGridTextColumn Header="Khách" Binding="{Binding NumberOfGuests}" Width="60"/>
                    <DataGridTextColumn Header="Tiền" Binding="{Binding TotalPrice, StringFormat={}{0:N0}}" Width="110"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="100"/>
                    <DataGridTextColumn Header="Hóa đơn" Binding="{Binding InvoiceCode}" Width="110"/>
                    <DataGridTextColumn Header="TT hóa đơn" Binding="{Binding InvoiceStatus}" Width="100"/>
                    <DataGridTemplateColumn Header="Thao tác" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Check-in" Width="70" Height="28" Margin="0,0,6,0" Click="BtnCheckIn_Click"/>
                                    <Button Content="Checkout" Width="72" Height="28" Margin="0,0,6,0" Click="BtnCheckOut_Click"/>
                                    <Button Content="Thanh toán" Width="78" Height="28" Click="BtnPaid_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock x:Name="txtSummary"
                       Grid.Row="2"
                       Margin="10,0,10,10"
                       FontWeight="SemiBold"/>
        </Grid>
    </Grid>
</Window>
