<Window x:Class="staymanager_pj.Views.Management.InvoiceManagementPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý hóa đơn" Height="720" Width="1100" WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Quản lý hóa đơn" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button x:Name="btnRefresh" Content="Tải lại" Width="80" Height="32" Margin="24,0,8,0"/>
            <Button x:Name="btnPaid" Content="Thanh toán" Width="100" Height="32"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="dgInvoices" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" Margin="0,0,12,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã" Binding="{Binding InvoiceCode}" Width="120"/>
                    <DataGridTextColumn Header="Đặt phòng" Binding="{Binding ReservationId}" Width="80"/>
                    <DataGridTextColumn Header="Khách" Binding="{Binding CustomerId}" Width="70"/>
                    <DataGridTextColumn Header="Phòng" Binding="{Binding RoomId}" Width="70"/>
                    <DataGridTextColumn Header="Tiền phòng" Binding="{Binding RoomCharge}" Width="110"/>
                    <DataGridTextColumn Header="Dịch vụ" Binding="{Binding ServiceCharge}" Width="110"/>
                    <DataGridTextColumn Header="Giảm" Binding="{Binding Discount}" Width="90"/>
                    <DataGridTextColumn Header="Tổng" Binding="{Binding TotalAmount}" Width="110"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="110"/>
                    <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Thông tin hóa đơn" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBlock Text="Mã"/><TextBox x:Name="txtCode" Margin="0,4,0,8"/>
                <TextBlock Text="Mã đặt phòng"/><TextBox x:Name="txtReservationId" Margin="0,4,0,8"/>
                <TextBlock Text="Mã khách"/><TextBox x:Name="txtCustomerId" Margin="0,4,0,8"/>
                <TextBlock Text="Mã phòng"/><TextBox x:Name="txtRoomId" Margin="0,4,0,8"/>
                <TextBlock Text="Tiền phòng"/><TextBox x:Name="txtRoomCharge" Margin="0,4,0,8"/>
                <TextBlock Text="Dịch vụ"/><TextBox x:Name="txtServiceCharge" Margin="0,4,0,8"/>
                <TextBlock Text="Giảm giá"/><TextBox x:Name="txtDiscount" Margin="0,4,0,10"/>
                <WrapPanel Margin="0,0,0,14">
                    <Button x:Name="btnNew" Content="Mới" Width="70" Height="32" Margin="0,0,8,8"/>
                    <Button x:Name="btnSave" Content="Lưu" Width="70" Height="32" Margin="0,0,8,8"/>
                </WrapPanel>

                <TextBlock Text="Chi tiết dịch vụ" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                <ListBox x:Name="lstItems" Height="110" Margin="0,0,0,8"/>
                <TextBlock Text="Tên dịch vụ/vật tư"/><TextBox x:Name="txtItemName" Margin="0,4,0,8"/>
                <TextBlock Text="Số lượng"/><TextBox x:Name="txtItemQty" Margin="0,4,0,8"/>
                <TextBlock Text="Đơn giá"/><TextBox x:Name="txtItemPrice" Margin="0,4,0,8"/>
                <Button x:Name="btnAddItem" Content="Thêm chi tiết" Height="34"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

