<Window x:Class="staymanager_pj.Views.Management.AnalyticsPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:staymanager_pj.Views.Shared"
        Title="Thống kê" Height="900" Width="1200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:Sidebar Grid.Column="0" Loaded="Sidebar_Loaded"/>
        <ScrollViewer Grid.Column="1">
            <StackPanel Margin="20">
                <TextBlock Text="Thống kê tổng quan" FontSize="24" FontWeight="Bold" Margin="10"/>
                <ItemsControl x:Name="icDashboardStats" Margin="10"/>
                <TextBlock Text="Doanh thu" FontSize="20" FontWeight="Bold" Margin="10"/>
                <ItemsControl x:Name="icRevenueStats" Margin="10"/>
                <TextBlock Text="Tình trạng phòng" FontSize="20" FontWeight="Bold" Margin="10"/>
                <ItemsControl x:Name="icRoomStats" Margin="10"/>
                <TextBlock Text="Vật tư" FontSize="20" FontWeight="Bold" Margin="10"/>
                <ItemsControl x:Name="icInventoryStats" Margin="10"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
