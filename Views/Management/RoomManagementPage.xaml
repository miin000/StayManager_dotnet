<Window x:Class="staymanager_pj.Views.Management.RoomManagementPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:staymanager_pj.Views.Shared"
        Title="Quản lý phòng" Height="900" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <local:Sidebar Grid.Column="0"/>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Margin="10">
                <TextBlock Text="Quản lý Tình trạng Phòng" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button x:Name="btnRefresh" Content="Tải lại" Width="100" Height="32" DockPanel.Dock="Right"/>
            </DockPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icRooms" Margin="10">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="290" Margin="0,0,16,16" Padding="16" CornerRadius="10" BorderBrush="#FFD0D7E2" BorderThickness="1" Background="WhiteSmoke">
                                <StackPanel>
                                    <TextBlock Text="{Binding Room.RoomNumber, StringFormat=Phòng {0}}" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Room.RoomType, StringFormat=Loại: {0}}" Margin="0,6,0,0"/>
                                    <TextBlock Text="{Binding Room.Capacity, StringFormat=Sức chứa: {0} khách}" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding Room.PricePerNight, StringFormat=Giá: {0:N0} VNĐ/đêm}" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding Room.Description}" TextWrapping="Wrap" Margin="0,8,0,8" MinHeight="40"/>
                                    <TextBlock Text="{Binding Room.Status, StringFormat=Hiện tại: {0}}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <ComboBox ItemsSource="{Binding AvailableStatuses}" SelectedItem="{Binding SelectedStatus}" Margin="0,0,0,8"/>
                                    <Button Content="Cập nhật tình trạng" Height="34" Click="BtnUpdateStatus_Click"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
