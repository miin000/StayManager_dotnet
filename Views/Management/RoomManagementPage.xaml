<Window x:Class="staymanager_pj.Views.Management.RoomManagementPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:staymanager_pj.Views.Shared"
        Title="Quản lý phòng" Height="900" Width="1200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <local:Sidebar Grid.Column="0"/>

        <StackPanel Grid.Column="1" Margin="20">
            <TextBlock Text="Quản lý Tình trạng Phòng" FontSize="24" FontWeight="Bold" Margin="10"/>
            <ItemsControl x:Name="icRooms"/>
        </StackPanel>
    </Grid>
</Window>
