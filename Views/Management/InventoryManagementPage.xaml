<Window x:Class="staymanager_pj.Views.Management.InventoryManagementPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý vật tư" Height="720" Width="1100" WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Quản lý vật tư" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBox x:Name="txtSearch" Width="260" Height="32" Margin="24,0,8,0" VerticalContentAlignment="Center" ToolTip="Tìm mã/tên/loại"/>
            <Button x:Name="btnSearch" Content="Tìm" Width="70" Height="32" Margin="0,0,8,0"/>
            <Button x:Name="btnRefresh" Content="Tải lại" Width="80" Height="32"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="dgInventory" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" Margin="0,0,12,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã" Binding="{Binding ItemCode}" Width="90"/>
                    <DataGridTextColumn Header="Tên vật tư" Binding="{Binding ItemName}" Width="*"/>
                    <DataGridTextColumn Header="Loại" Binding="{Binding Category}" Width="120"/>
                    <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="70"/>
                    <DataGridTextColumn Header="Tối thiểu" Binding="{Binding MinimumQuantity}" Width="80"/>
                    <DataGridTextColumn Header="Đơn vị" Binding="{Binding Unit}" Width="80"/>
                    <DataGridTextColumn Header="Giá nhập" Binding="{Binding ImportPrice}" Width="100"/>
                    <DataGridTextColumn Header="Giá bán" Binding="{Binding SellingPrice}" Width="100"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Thông tin" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBlock Text="Mã"/><TextBox x:Name="txtCode" Margin="0,4,0,8"/>
                <TextBlock Text="Tên vật tư"/><TextBox x:Name="txtName" Margin="0,4,0,8"/>
                <TextBlock Text="Loại"/><TextBox x:Name="txtCategory" Margin="0,4,0,8"/>
                <TextBlock Text="Số lượng"/><TextBox x:Name="txtQuantity" Margin="0,4,0,8"/>
                <TextBlock Text="Tối thiểu"/><TextBox x:Name="txtMinimum" Margin="0,4,0,8"/>
                <TextBlock Text="Đơn vị"/><TextBox x:Name="txtUnit" Margin="0,4,0,8"/>
                <TextBlock Text="Giá nhập"/><TextBox x:Name="txtImportPrice" Margin="0,4,0,8"/>
                <TextBlock Text="Giá bán"/><TextBox x:Name="txtSellingPrice" Margin="0,4,0,8"/>
                <TextBlock Text="Ghi chú"/><TextBox x:Name="txtNote" Margin="0,4,0,10" Height="55" TextWrapping="Wrap" AcceptsReturn="True"/>

                <WrapPanel Margin="0,0,0,14">
                    <Button x:Name="btnNew" Content="Mới" Width="70" Height="32" Margin="0,0,8,8"/>
                    <Button x:Name="btnSave" Content="Lưu" Width="70" Height="32" Margin="0,0,8,8"/>
                    <Button x:Name="btnDelete" Content="Xóa" Width="70" Height="32" Margin="0,0,8,8"/>
                </WrapPanel>

                <TextBlock Text="Nhập kho" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBlock Text="SL nhập"/><TextBox x:Name="txtImportQty" Margin="0,4,0,8"/>
                <TextBlock Text="Đơn giá"/><TextBox x:Name="txtImportUnitPrice" Margin="0,4,0,8"/>
                <TextBlock Text="Nhà cung cấp"/><TextBox x:Name="txtSupplier" Margin="0,4,0,8"/>
                <Button x:Name="btnImport" Content="Nhập kho" Height="34"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

